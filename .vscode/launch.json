{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run DEV App (Debug)",
      "type": "dart",
      "program": "lib/main.dart",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "args": [
        "--dart-define-from-file=config/production.json",
      ],
      "env": {}
    },
    {
      "name": "Run DEV App (Debug, Drop database)",
      "type": "dart",
      "program": "lib/main.dart",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "args": [
        "--dart-define-from-file=config/production.json",
        "--dart-define=DROP_DATABASE=true"
      ],
      "env": {}
    },
    {
      "name": "Run DEV App (Debug, Memmory database)",
      "type": "dart",
      "program": "lib/main.dart",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "args": [
        "--dart-define-from-file=config/production.json",
        "--dart-define=IN_MEMORY_DATABASE=true"
      ],
      "env": {}
    },
    {
      "name": "Run DEV Web Server (Debug)",
      "type": "dart",
      "program": "lib/main.dart",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "args": [
        "--dart-define-from-file=config/production.json",
        "--device-id=web-server",
      ],
      "env": {}
    },
    {
      "name": "Run DEV Web Chrome (Debug)",
      "type": "dart",
      "program": "lib/main.dart",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "args": [
        "--dart-define-from-file=config/production.json",
        "--device-id=chrome",
        "--web-hostname=localhost",
        "--web-port=8080",
      ],
      "env": {}
    }
  ]
}